# Dashboard Administrator Password (optional, default: admin@890.COM)
DASHBOARD_ADMIN_PASSWORD=your_dashboard_password

# APISIX Admin API Key (default: ffffc9f034335f136f87ad84b625dddd)
APISIX_ADMIN_KEY=ffffc9f034335f136f87ad84b625dddd

# Aliyun DNS API Keys for acme.sh (required for SSL certificate)
Ali_Key=your_aliyun_access_key
Ali_Secret=your_aliyun_secret_key

# ACME Domains (semicolon separates cert groups, comma separates domains in group)
# Single cert: ACME_DOMAINS=example.com,*.example.com
# Multi cert:  ACME_DOMAINS=a.com,*.a.com; b.com,*.b.com
ACME_DOMAINS=example.com,*.example.com

# ACME DNS Provider (default: dns_ali, see https://github.com/acmesh-official/acme.sh/wiki/dnsapi)
# ACME_DNS_PROVIDER=dns_ali

# ACME Account Email (pre-register account for faster first-time issuance + expiry notifications)
ACME_EMAIL=your-email@example.com

# ACME CA Server (default: letsencrypt, options: letsencrypt, zerossl, buypass, google, etc.)
# ACME_CA_SERVER=letsencrypt

# Redis Password (for built-in or external Redis)
REDIS_PASSWORD=apisix_redis

# External Redis (optional, set to skip built-in Redis)
# REDIS_EXTERNAL_HOST=your-redis-host
# REDIS_EXTERNAL_PORT=6379
